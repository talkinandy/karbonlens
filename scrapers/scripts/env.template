# KarbonLens VPS env file — copied to /opt/karbonlens/.env by install-crontab.sh.
# File owner must be karbonlens:karbonlens, mode 0640.
# Every wrapper script in /opt/karbonlens/scripts/ sources this via:
#   set -a; source /opt/karbonlens/.env; set +a
# See docs/runbooks/cron-install.md for key-by-key sourcing.
#
# After install-crontab.sh bootstraps the file from this template, edit it in
# place with real secrets, then re-run install-crontab.sh.
#
# DIGEST_CRON_SECRET is generated freshly by install-crontab.sh during
# bootstrap; the literal CHANGE_ME below is a placeholder that never lands
# on disk. All other CHANGE_ME values must be replaced manually.

DATABASE_URL="postgresql://karbonlens:CHANGE_ME@localhost:5432/karbonlens?sslmode=disable"
PGPASSWORD="CHANGE_ME"
GFW_API_KEY="CHANGE_ME"
RESEND_API_KEY="CHANGE_ME"
DIGEST_CRON_SECRET="CHANGE_ME"
APP_BASE_URL="http://localhost:3001"
SCRAPER_LOG_DIR="/var/log/karbonlens"
SCRAPER_USER_AGENT="KarbonLens/0.1 (+https://karbonlens.id)"
