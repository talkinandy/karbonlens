# .env.example — KarbonLens v0.1
# Copy to .env.local and populate before running npm run dev.
# Never commit .env.local — it is gitignored.
#
# Key index (story that consumes each var):
#   DATABASE_URL         -> T04 (Drizzle client) + scrapers
#   NEXTAUTH_URL         -> T05 (NextAuth redirect base)
#   NEXTAUTH_SECRET      -> T05 (NextAuth session signing; generate: openssl rand -base64 32)
#   GOOGLE_CLIENT_ID     -> T05 (Google OAuth)
#   GOOGLE_CLIENT_SECRET -> T05 (Google OAuth)
#   GFW_API_KEY          -> T07/T13 (Global Forest Watch API)
#   RESEND_API_KEY       -> T17 (email digest)
#   SENTRY_DSN           -> T22 (error tracking; optional in dev)
#   ADMIN_EMAILS         -> T21/T22 (comma-separated admin allowlist)

# ── Database ────────────────────────────────────────────────────────────────
# For local dev: SSL not required on localhost (sslmode=disable).
# For Netlify deploy (v0.2+): replace localhost with VPS public IP or
#   Tailscale IP and update pg_hba.conf. See T04 for connectivity options.
DATABASE_URL=postgresql://karbonlens:CHANGE_ME@localhost:5432/karbonlens?sslmode=disable

# ── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── External APIs ───────────────────────────────────────────────────────────
GFW_API_KEY=CHANGE_ME
RESEND_API_KEY=CHANGE_ME

# ── Error tracking ──────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Admin allowlist ─────────────────────────────────────────────────────────
# Comma-separated list of emails granted admin access (match-queue,
# debug endpoints, etc). Missing/empty disables admin access entirely.
ADMIN_EMAILS=

# NextAuth v5 UntrustedHost bypass — required when running behind a reverse
# proxy (nginx / Caddy / Netlify). Set to `true` in production. NextAuth
# uses this to trust the X-Forwarded-Host header; without it you'll see
# [auth][error] UntrustedHost on every request to /api/auth/session.
AUTH_TRUST_HOST=true
